import io.github.bonigarcia.wdm.WebDriverManager;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.testng.Assert;
import org.testng.annotations.AfterClass;
import org.testng.annotations.BeforeClass;
import org.testng.annotations.Test;

public class LoginTest {

    WebDriver driver;

    @BeforeClass
    public void setup() {
        WebDriverManager.chromedriver().setup();
        driver = new ChromeDriver();
        driver.manage().window().maximize();
        driver.get("http://localhost/index.html");
    }

    @Test(priority = 1)
    public void loginWithEmptyFields() {
        driver.findElement(By.tagName("button")).click();

        WebElement error = driver.findElement(By.id("errorMsg"));
        Assert.assertTrue(error.getText().contains("required"));
    }

    @Test(priority = 2)
    public void loginWithShortPassword() {
        driver.findElement(By.id("username")).sendKeys("admin");
        driver.findElement(By.id("password")).sendKeys("123");
        driver.findElement(By.tagName("button")).click();

        WebElement error = driver.findElement(By.id("errorMsg"));
        Assert.assertEquals(error.getText(), "Password must be at least 6 characters.");
    }

    @Test(priority = 3)
    public void loginWithInvalidCredentials() {
        driver.navigate().refresh();

        driver.findElement(By.id("username")).sendKeys("invalidUser");
        driver.findElement(By.id("password")).sendKeys("invalid123");
        driver.findElement(By.tagName("button")).click();

        WebElement body = driver.findElement(By.tagName("body"));
        Assert.assertTrue(body.getText().contains("Invalid username or password"));
    }

    @Test(priority = 4)
    public void loginWithValidCredentials() {
        driver.navigate().to("http://localhost/index.html");

        driver.findElement(By.id("username")).sendKeys("admin");
        driver.findElement(By.id("password")).sendKeys("admin123");
        driver.findElement(By.tagName("button")).click();

        String currentUrl = driver.getCurrentUrl();
        Assert.assertTrue(currentUrl.contains("dashboard.php"));
    }

    @AfterClass
    public void tearDown() {
        driver.quit();
    }
}

